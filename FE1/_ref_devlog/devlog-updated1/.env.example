# ─── ENVIRONMENT VARIABLES ───────────────────────────────────────────────────
# Copy file này thành .env.local rồi điền vào

# URL backend API — vite proxy /api → địa chỉ này khi dev
VITE_API_URL=http://localhost:4000/api

# Auth (nếu dùng JWT)
# VITE_AUTH_TOKEN_KEY=devlog_token

# Feature flags
# VITE_ENABLE_EDITOR_AI=false
